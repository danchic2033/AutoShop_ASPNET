@model Order

<div class="container py-5 h-100">
    <div class="row d-flex justify-content-center align-items-center h-100">
      <div class="col-12">
        <div class="card card-registration card-registration-2" style="border-radius: 15px;">
          <div class="card-body p-0">
            <div class="row g-0">
              <div class="col-lg-8">
                <div class="p-5">
                  <div class="d-flex justify-content-between align-items-center mb-5">
                    <h1 class="fw-bold mb-0">Ваша корзина</h1>
                  </div>

                  @* Отображение элементов корзины *@
            @if(Model.CartItems.Count != 0)
            {
                  @for (int i = 0; i < Model.CartItems.Count; i++)
                  {
                      <hr class="my-4">
                      <div class="row mb-4 d-flex justify-content-between align-items-center">
                        <div class="col-md-2 col-lg-2 col-xl-2">
                          <img
                            src="/img/stopPhoto.jpg"
                            class="img-fluid rounded-3" alt="">
                        </div>
                        <div class="col-md-3 col-lg-3 col-xl-3">
                          <h6 class="mb-0">@Model.CartItems[i].Product.Name</h6>
                        </div>
                        <div class="col-md-3 col-lg-3 col-xl-2 d-flex">
                          <a asp-controller="Cart" asp-action="DecreaseItemInCart" asp-route-id="@Model.CartItems[i].Product.Id" class="btn btn-link px-2">
                            <i class="fas fa-minus"></i>
                          </a> 

                          <input id="form1" min="0" name="quantity" value="@Model.CartItems[i].ItemQuantity" type="number"
                            class="form-control form-control-sm" />

                          <a asp-controller="Cart" asp-action="IncreaseItemInCart" asp-route-id="@Model.CartItems[i].Product.Id" class="btn btn-link px-2">
                            <i class="fas fa-plus"></i>
                          </a> 
                        </div>
                        <div class="col-md-3 col-lg-2 col-xl-2 offset-lg-1">
                          <h6 class="mb-0">@Model.CartItems[i].ItemCost.ToString("c")</h6>
                        </div>
                        <div class="col-md-1 col-lg-1 col-xl-1 text-end">
                          <a asp-controller="Cart" asp-action="ClearCart" class="text-muted">
                              <i class="fas fa-times"></i>
                              </a>
                              @* Доработать отчистку корзины *@
                        </div>
                      </div>
                  }

                  @* Отображение элементов корзины *@
              }
              else
              {
                  <hr class="my-4">
                  <div class="d-flex justify-content-between mb-4">
                    <h5 class="text-uppercase">Ваша корзина пуста =(</h5>
                  </div>
              }

                  <hr class="my-4">

                  <div class="pt-5">
                    <h6 class="mb-0"><a asp-controller="Home" asp-action="Index" class="text-body"><i
                          class="fas fa-long-arrow-alt-left me-2"></i>Вернуться в магазин</a></h6>
                  </div>
                </div>
              </div>
              <form method="post">
              <div class="col-lg-4 bg-body-tertiary">
                <div class="p-5">
                  <h3 class="fw-bold mb-5 mt-2 pt-1">Итог</h3>
                  <hr class="my-4">

                  <div class="text-danger fw-bold text-uppercase" asp-validation-summary="All"></div>
                  
                  <h5 class="text-uppercase mb-3">Введите данные для доставки</h5>

                  <div class="mb-5">
                    <div data-mdb-input-init class="form-outline">
                      <input type="text" id="Name" asp-for="DeliveryUserInfo.Name" class="form-control form-control-lg"/>
                      <label class="form-label" asp-for="DeliveryUserInfo.Name">Введите имя</label>
                      <span asp-validation-for="DeliveryUserInfo.Name" class="text-danger"></span>
                    </div>
                  </div>

                  <div class="mb-5">
                    <div data-mdb-input-init class="form-outline">
                      <input type="text" id="Address" asp-for="DeliveryUserInfo.Address" class="form-control form-control-lg"/>
                      <label class="form-label" asp-for="DeliveryUserInfo.Address">Введите адрес доставки</label>
                      <span asp-validation-for="DeliveryUserInfo.Address" class="text-danger"></span>
                    </div>
                  </div>

                  <div class="mb-5">
                    <div data-mdb-input-init class="form-outline">
                      <input type="text" id="PhoneNumber" asp-for="DeliveryUserInfo.PhoneNumber" class="form-control form-control-lg"/>
                      <label class="form-label" asp-for="DeliveryUserInfo.PhoneNumber">Введите телефон для связи</label>
                      <span asp-validation-for="DeliveryUserInfo.PhoneNumber" class="text-danger"></span>
                    </div>
                  </div>

                  <div class="mb-5">
                    <div data-mdb-input-init class="form-outline">
                      <input type="text" id="DateDelivery" asp-for="DeliveryUserInfo.DateDelivery" class="form-control form-control-lg"/>
                      <label class="form-label" asp-for="DeliveryUserInfo.DateDelivery">Выберите дату доставки</label>
                      <span asp-validation-for="DeliveryUserInfo.DateDelivery" class="text-danger"></span>
                    </div>
                  </div>

                  <div class="mb-5">
                    <div data-mdb-input-init class="form-outline">
                      <input type="text" id="Comment" asp-for="DeliveryUserInfo.Comment" class="form-control form-control-lg"/>
                      <label class="form-label" asp-for="DeliveryUserInfo.Comment">Комментарий</label>
                      <span asp-validation-for="DeliveryUserInfo.Comment" class="text-danger"></span>
                    </div>
                  </div>

                  <hr class="my-4">

                  <div class="d-flex justify-content-between mb-5">
                    <h5 class="text-uppercase">К оплате:</h5>
                    <h5>@Model.TotalCost.ToString()</h5>
                  </div>

                  <button type ="submit" asp-controller="Order" asp-action="SuccessOrder" class="btn btn-dark btn-block btn-lg"
                    data-mdb-ripple-color="dark">Заказать
                  </button>
                </div>
              </div>
              </form>
          </div>
        </div>
      </div>
    </div>
  </div>
  </div>