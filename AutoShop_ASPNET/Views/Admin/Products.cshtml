@model List<Product>

<div class="d-flex align-items-center justify-content-between" style="width: 50%;">
    <div class="d-grid gap-2 col-6">
        <a class="btn btn-primary" asp-controller="Admin" asp-action="Index" type="button">Заказы</a>
        <a class="btn btn-primary" asp-controller="Admin" asp-action="Users" type="button">Пользователи</a>
        <a class="btn btn-primary" asp-controller="Admin" asp-action="Roles" type="button">Роли</a>
        <a class="btn btn-primary" asp-controller="Admin" asp-action="Products" type="button">Товары</a>
    </div>
    <div class="ms-3">
        <span class="text" style="font-size: 1.5rem;">Товары</span>
</div>
</div>

    <div class="container py-5 h-100">
        <div class="row d-flex justify-content-center align-items-center h-100">
            <div class="col-12">
                <div class="card card-registration card-registration-2" style="border-radius: 15px;">
                    <div class="card-body p-0">
                        <div class="row g-0">
                            <div class="col">
                                <div class="p-5">
                                    <div class="d-flex justify-content-between align-items-center mb-5">
                                        <h1 class="fw-bold mb-0">Товары</h1>
                                        <div class="col-md-3 col-lg-3 col-xl-3 text-end">
                                                    <a asp-controller="Cart" asp-action="ClearCart" class="text">
                                                        <span class="text">Добавить новый товар</span>
                                                    </a>
                                                    @* Доработать отчистку корзины *@
                                                </div>
                                    </div>
                                    @if (Model != null && Model.Count != 0)
                                    {
                                        @for (int i = 0; i < Model.Count; i++)
                                        {
                                            <hr class="my-4">
                                            <div class="row mb-4 d-flex justify-content-between align-items-center">
                                                <div class="col-md-2 col-lg-2 col-xl-2">
                                                    <img src="/img/stopPhoto.jpg"
                                                         class="img-fluid rounded-3" alt="">
                                                </div>
                                                <div class="col-md-3 col-lg-3 col-xl-3">
                                                    <h6 class="mb-0">@Model[i].Name</h6>
                                                </div>
                                                <div class="col-md-3 col-lg-2 col-xl-2 offset-lg-1">
                                                    <h6 class="mb-0">@Model[i].Cost.ToString("c")</h6>
                                                </div>
                                                <div class="col-md-3 col-lg-3 col-xl-3 text-end">
                                                    <a asp-controller="Cart" asp-action="ClearCart" class="text">
                                                        <span class="text">Редактировать</span>
                                                    </a>
                                                    @* Доработать отчистку корзины *@
                                                </div>
                                                <div class="col-md-1 col-lg-1 col-xl-1 text-end">
                                                <a asp-controller="Admin" asp-action="RemoveItem" class="text">
                                                        <span class="text">Удалить</span>
                                                    </a>
                                                    @* Доработать отчистку корзины *@
                                                </div>
                                            </div>
                                        }
                                    }
                                    else
                                    {
                                        <hr class="w-100 my-4">
                                        <div class="d-flex justify-content-between mb-4">
                                            <h5 class="text-uppercase">Нет товаров в вашем магазине</h5>
                                        </div>
                                    }

                                    <hr class="my-4">

                                    <div class="pt-5">
                                        <h6 class="mb-0">
                                            <a asp-controller="Home" asp-action="Index" class="text-body">
                                                <i class="fas fa-long-arrow-alt-left me-2"></i>Вернуться в магазин
                                            </a>
                                        </h6>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
