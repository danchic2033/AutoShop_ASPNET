@model Order
@{
    ViewData["Title"] = "Детали заказа";
}

<div class="row mt-3">
    @await Html.PartialAsync("SideBar")


    <div class="col-9 mb-3">
        <div class="text-center text-uppercase text-success mb-5 mt-5">
            <h2 class="row-title">Детали заказа</h2>
        </div>
        <form method="post">

            @if (Model != null)
            {
                <input type="hidden" name="Id" value="ID_ЗАКАЗА" />

                <table class="table table-responsive mb-5 caption-top">
                    <tr>
                        <td class="fw-bold border-end border-bottom border-dark">Заказ</td>
                        <td class="border-bottom border-dark">

                            <table class="table table-hover">
                                <tr>
                                    <td class="w-25"><span>ID</span></td>
                                    <td class="w-auto">ID_ЗАКАЗА</td>
                                </tr>
                                <tr>
                                    <td class="w-25"><span>Стоимость</span></td>
                                    <td class="fw-bold w-auto">СУММА_ЗАКАЗА</td>
                                </tr>
                                <tr>
                                    <td class="w-25"><span>Количество позиций</span></td>
                                    <td class="w-auto">КОЛИЧЕСТВО_ПОЗИЦИЙ_В_ЗАКАЗЕ</td>
                                </tr>
                                <tr>
                                    <td class="w-25"><span>Количество товаров</span></td>
                                    <td class="w-auto">КОЛИЧЕСТВО_ТОВАРОВ_В_ЗАКАЗЕ</td>
                                </tr>
                                <tr>
                                    <td class="w-25"><span>Статус заказа</span></td>
                                    <td class="w-auto">
                                        <p>
                                            @* <select asp-for="СТАТУС_ЗАКАЗА"
                                                    class="form-select list-group-item-success w-50"
                                                    asp-items="@Html.GetEnumSelectList<OrderStatus>()">
                                            </select> *@
                                        </p>

                                    </td>
                                </tr>
                                <tr>
                                    <td class="w-25"><span>Время создания заказа</span></td>
                                    <td class="w-auto">ДАТА_И_ВРЕМЯ_СОЗДАНИЯ_ЗАКАЗА</td>
                                </tr>
                            </table>
                        </td>
                    </tr>
                    <tr>
                        <td class="fw-bold border-end border-bottom border-dark">Пользователь</td>
                        <td class="border-bottom border-dark">
                            <table class="table table-hover">
                                <tr>
                                    <td class="w-25"><span>ID</span></td>
                                    <td class="w-auto">ПОЛЬЗОВАТЕЛЬ</td>
                                </tr>
                            </table>
                        </td>
                    </tr>
                    <tr>
                        <td class="fw-bold border-end border-bottom border-dark">Покупатель</td>
                        <td class="border-bottom border-dark">
                            <table class="table table-hover p-0 m-0">
                                <tr>
                                    <td class="w-25"><span>ID</span></td>
                                    <td class="w-auto">ID_ПОКУПАТЕЛЯ</td>
                                </tr>
                                <tr>
                                    <td class="w-25"><span>Имя</span></td>
                                    <td class="w-auto">ИМЯ_ПОКУПАТЕЛЯ</td>
                                </tr>
                                <tr>
                                    <td class="w-25"><span>Телефон</span></td>
                                    <td class="w-auto">ТЕЛЕФОН_ПОКУПАТЕЛЯ</td>
                                </tr>
                                <tr>
                                    <td class="w-25"><span>Адрес</span></td>
                                    <td class="w-auto">АДРЕС_ПОКУПАТЕЛЯ</td>
                                </tr>
                                <tr>
                                    <td class="w-25"><span>Дата доставки</span></td>
                                    <td class="w-auto">ДАТА_ДОСТАВКИ_ЗАКАЗА</td>
                                </tr>
                                <tr>
                                    <td class="w-25"><span>Комментарий</span></td>
                                    <td class="w-auto">КОММЕНТАРИЙ</td>
                                </tr>
                            </table>
                        </td>
                    </tr>
                    <tr>
                        <td class="fw-bold border-end border-dark">Состав заказа</td>
                        <td class="border-bottom border-dark">
                            <table class="table table-responsive
                                 table-striped table-hover caption-top">
                                <thead>
                                    <tr align="center">
                                        <th scope="col">#</th>
                                        <th scope="col">Наименование товара</th>
                                        <th scope="col">Цена, руб.</th>
                                        <th scope="col">Количество, шт.</th>
                                        <th scope="col">Стоимость, руб.</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @for (var i = 0; i < Model.CartItems.Count; i++)
                                    {
                                        <tr align="center" class="align-baseline">
                                            <td class="fw-bold">@(i + 1)</td>
                                            <td align="left">НАИМЕНОВАНИЕ_ТОВАРА</td>
                                            <td align="left">ЦЕНА_ТОВАРА</td>
                                            <td>КОЛИЧЕСТВО_ТОВАРА</td>
                                            <td class="fw-bold">СТОИМОСТЬ_ТОВАРА</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </td>
                    </tr>
                </table>

                <div class="text-center mt-5">
                    <button class="btn btn-outline-success" type="ОТПРАВКА_ДАННЫХ_ФОРМЫ"
                            asp-controller="КОНТРОЛЛЕР"
                            asp-action="МЕТОД_КОНТРОЛЛЕРА"
                            asp-route-orderId=ID_ТОВАРА>
                        Обновить статус
                    </button>
                </div>
            }
            else
            {
                <div class="text-center">
                    <h2>Такого заказа не существует!</h2>
                </div>
            }
        </form>
    </div>
</div>