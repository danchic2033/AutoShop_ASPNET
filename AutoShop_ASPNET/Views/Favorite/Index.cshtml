@model List<Favorite>

<div class = "container">
    <div class ="row">
        @if (Model != null)
        {
            @for (int i = 0; i < Model.Count; i++)
            {   
                <div class = "col-4 mb-4">
                    <a asp-controller="product" asp-action="index" asp-route-id="@Model[i].Product.Id" class="text-decoration-none text-dark">
                    <div class="card" style="width: 18rem;">
                      <img src="/img/stopPhoto.jpg" class="card-img-top" alt="...">
                      <div class="card-body">
                        <h5 class="card-title">@Model[i].Product.Name</h5>
                        <p clss = "cart-cost">@Model[i].Product.Cost.ToString("c")</p>
                        <a asp-controller="Cart" asp-action="AddToCart" asp-route-id="@Model[i].Product.Id" class="btn btn-primary">Добавить в корзину</a>
                      </div>
                    </div>
                    </a>
                </div>
            }
        }
        else
        {
            <h5>Нет товаров для отображения</h5>
        }
    </div>
</div>